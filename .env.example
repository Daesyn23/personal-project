NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never NEXT_PUBLIC_* or expose to browser. Enables saving the Google Sheets OAuth refresh token in Postgres
# (workspace_google_sheets_oauth) so you do not need GOOGLE_REFRESH_TOKEN in env on Vercel after “Connect Google”.
SUPABASE_SERVICE_ROLE_KEY=
# With Supabase configured, saved Google Sheet links + worksheet UI prefs sync for all app users (shared row).
# Apply migrations including workspace_google_sheets_settings (global id), workspace_google_sheets_oauth_secret, and youtube_lesson_notes.

# YouTube (server-only) — full JLPT playlists via Data API v3 (not just RSS). Either set a key below OR rely on
# “Connect Google” OAuth (same GCP project must enable YouTube Data API — see GOOGLE_CLIENT_* block).
# Enable API: https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=    
# Optional fallback if you use one Google Cloud API key with YouTube Data API enabled:
# GOOGLE_API_KEY=

# Google Sheets + linked YouTube playlists (server-only — do not use NEXT_PUBLIC_ prefix)
# Create an OAuth client (Desktop or Web) and enable Sheets API AND YouTube Data API v3 on the same GCP project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. If unset, the app uses http(s)://<host>/api/google-sheets/callback — add that exact URL in Google Cloud.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-sheets/callback
# Optional. Local dev: leave unset and use “Connect Google” — token is saved under data/google-sheets-refresh-token (or OS temp if data/ is not writable).
# Vercel / any read-only disk: after OAuth, paste the line from the callback page into env (see .env.local locally, or Vercel → Environment Variables). Redeploy on Vercel. Do not commit the token.
GOOGLE_REFRESH_TOKEN=

# LLM keys: copy this file to .env.local in the project root (same folder as package.json). Use exact names below.
# Restart `npm run dev` after any change — Next.js only reads env at server startup.

# OpenAI (server-only) — Chat Completions backup after Gemini + Groq; Whisper backup after Groq for audio lessons;
# flashcard image import uses Gemini first when set, then OpenAI vision.
OPENAI_API_KEY=
# Optional — chat backup model when Gemini/Groq fail or are unset (default: gpt-4o-mini).
# OPENAI_CHAT_MODEL=gpt-4o-mini
# Optional — vision model for Flashcards → “Import from image (AI)” when Gemini is unavailable or returns bad JSON (default: gpt-4o-mini).
# OPENAI_VISION_MODEL=gpt-4o-mini
# Optional — set to `diarize` for OpenAI speaker labels, then the same smart sectioning. Default: Whisper only + smart merge.
# OPENAI_AUDIO_SECTIONING=diarize
# Optional — Whisper model for timestamps / diarize fallback (default: whisper-1).
# OPENAI_WHISPER_MODEL=whisper-1
# Optional — Practice tab tutor voice (OpenAI TTS, same voice in JA/EN/TL). Default: nova
# OPENAI_TTS_VOICE=nova
# Optional — TTS model (default: gpt-4o-mini-tts for natural chat; tts-1 is faster but flatter)
# OPENAI_TTS_MODEL=gpt-4o-mini-tts
# Optional — TTS delivery style (used with gpt-4o-mini-tts only)
# OPENAI_TTS_INSTRUCTIONS=Speak naturally and conversationally, like a friendly tutor in a casual chat.

# Google Gemini (server-only — chat, translate, grammar, flashcard enrich). Optional: override model id.
GEMINI_API_KEY=
# Groq (server-only) — second text fallback after Gemini; first for phrase transcription when set (OpenAI Whisper is backup). https://console.groq.com/
GROQ_API_KEY=
# Optional Groq model id (default: llama-3.3-70b-versatile).
# GROQ_MODEL=llama-3.3-70b-versatile
# Optional — Groq Whisper model for Audio lesson phrase segmentation (default: whisper-large-v3-turbo).
# GROQ_WHISPER_MODEL=whisper-large-v3-turbo
# Optional. Defaults to gemini-2.5-flash. The API route retries other Flash models on quota/404.
# Flash / Flash-Lite are the usual free-tier models (same names as paid; limits are RPM/RPD/tokens per key).
# If you hit 429 often: try gemini-2.5-flash-lite, wait for the reset, or enable billing for higher limits.
# GEMINI_MODEL=gemini-2.5-flash-lite
# Optional. Set on 1/true only where your host allows long requests (e.g. local dev): one automatic wait+retry on 429.
# GEMINI_429_RETRY=1
