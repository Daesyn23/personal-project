NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never NEXT_PUBLIC_* or expose to browser. Enables saving the Google Sheets OAuth refresh token in Postgres
# (workspace_google_sheets_oauth) so you do not need GOOGLE_REFRESH_TOKEN in env on Vercel after “Connect Google”.
SUPABASE_SERVICE_ROLE_KEY=
# With Supabase configured, saved Google Sheet links + worksheet UI prefs sync for all app users (shared row).
# Apply migrations including workspace_google_sheets_settings (global id) and workspace_google_sheets_oauth_secret.

# Google Sheets (server-only — do not use NEXT_PUBLIC_ prefix)
# Create an OAuth client (Desktop or Web) in Google Cloud Console and enable the Sheets API.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional. If unset, the app uses http(s)://<host>/api/google-sheets/callback — add that exact URL in Google Cloud.
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google-sheets/callback
# Optional. Local dev: leave unset and use “Connect Google” — token is saved under data/google-sheets-refresh-token (or OS temp if data/ is not writable).
# Vercel / any read-only disk: after OAuth, paste the line from the callback page into env (see .env.local locally, or Vercel → Environment Variables). Redeploy on Vercel. Do not commit the token.
GOOGLE_REFRESH_TOKEN=

# LLM keys: copy this file to .env.local in the project root (same folder as package.json). Use exact names below.
# Restart `npm run dev` after any change — Next.js only reads env at server startup.

# Google Gemini (server-only — chat, translate, grammar, flashcard enrich). Optional: override model id.
GEMINI_API_KEY=
# Groq (server-only) — used if Gemini fails (quota/429) or if GEMINI_API_KEY is unset. https://console.groq.com/
GROQ_API_KEY=
# Optional Groq model id (default: llama-3.3-70b-versatile).
# GROQ_MODEL=llama-3.3-70b-versatile
# Optional. Defaults to gemini-2.5-flash. The API route retries other Flash models on quota/404.
# Flash / Flash-Lite are the usual free-tier models (same names as paid; limits are RPM/RPD/tokens per key).
# If you hit 429 often: try gemini-2.5-flash-lite, wait for the reset, or enable billing for higher limits.
# GEMINI_MODEL=gemini-2.5-flash-lite
# Optional. Set on 1/true only where your host allows long requests (e.g. local dev): one automatic wait+retry on 429.
# GEMINI_429_RETRY=1
